      "parameters": {
        "jsCode": "const lead = $input.first().json;\n\n// Search Google for publicly listed email for this person\nconst emailSearchBody = JSON.stringify({\n  q: '\"' + lead.firstName + ' ' + lead.lastName + '\" \"' + (lead.domain || lead.fullName) + '\" email contact',\n  num: 5\n});\n\nreturn [{\n  json: {\n    ...lead,\n    emailSearchBody\n  }\n}];"
      },
