    {
      "parameters": {
        "jsCode": "// Parse Groq response â€” carry full lead object forward\nconst groqResult = $input.first().json;\nconst lead = $('Build Groq Prompt').first().json;\n\nlet parsed;\ntry {\n  const raw = groqResult.choices[0].message.content;\n  const match = raw.match(/\\{[\\s\\S]*\\}/);\n  parsed = JSON.parse(match[0]);\n} catch(e) {\n  parsed = {\n    score: 5,\n    hooks: [],\n    reasoning: 'LLM parse failed',\n    subject: 'Following up',\n    body: `Hi ${lead.firstName}, I came across your profile and would love to connect. Are you open to a quick chat?`\n  };\n}\n\nreturn [{\n  json: {\n    ...lead,\n    score: parsed.score || 5,\n    hooks: Array.isArray(parsed.hooks) ? parsed.hooks.join(' | ') : (parsed.hooks || ''),\n    reasoning: parsed.reasoning || '',\n    message_subject: parsed.subject || '',\n    message_body: parsed.body || '',\n    groqBody: undefined\n  }\n}];"
      },
