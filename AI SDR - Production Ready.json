      "name": "Find LinkedIn Profiles"
    },
    {
      "parameters": {
        "jsCode": "const results = $input.first().json;\nconst organic = results.organic || [];\nconst formData = $('Parse Form Data').first().json;\nconst numLeads = formData.numLeads || 5;\n\nreturn organic.slice(0, numLeads).map((result, index) => {\n  const titleParts = result.title.split(' - ');\n  const fullName = titleParts[0].trim();\n  const nameParts = fullName.split(' ');\n  const firstName = nameParts[0] || '';\n  const lastName = nameParts.slice(1).join(' ') || '';\n\n  return {\n    json: {\n      leadId: `lead_${Date.now()}_${index}`,\n      fullName,\n      firstName,\n      lastName,\n      linkedinUrl: result.link,\n      linkedinSnippet: result.snippet || '',\n      industry: formData.industry,\n      location: formData.location,\n      jobTitle: formData.jobTitle,\n      yourService: formData.yourService || '',\n      domain: '',\n      email: '',\n      outreachMethod: 'linkedin',\n      research: '',\n      score: 0,\n      hooks: '',\n      reasoning: '',\n      message_subject: '',\n      message_body: '',\n      status: 'processing',\n      errors: []\n    }\n  };\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -3664,
        -112
      ],
      "id": "50156be1-cc95-47f0-998e-fb2f31d48a8a",
