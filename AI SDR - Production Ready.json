    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body;\nconst fields = body.data.fields;\n\nconst getValue = (label) => {\n  const field = fields.find(f => f.label === label);\n  return field ? field.value : '';\n};\n\nconst industry = getValue('Industry');\nconst location = getValue('Location');\nconst jobTitle = getValue('Job title to target');\nconst numLeads = parseInt(getValue('Number of leads')) || 5;\nconst yourService = getValue('Your service or product');\n\nconst searchQuery = `site:linkedin.com/in \"${jobTitle}\" \"${industry}\" \"${location}\"`;\n\nreturn [{\n  json: {\n    industry,\n    location,\n    jobTitle,\n    numLeads,\n    yourService,\n    searchQuery,\n    serperBody: JSON.stringify({ q: searchQuery, num: Math.min(numLeads, 10) })\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
