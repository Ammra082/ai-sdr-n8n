      "id": "978fa1b4-d927-4a65-896a-fc9a6d49939a",
      "name": "Process One at a Time"
    },
    {
      "parameters": {
        "jsCode": "const lead = $input.first().json;\n\n// Guard against empty batch trigger at end of loop\nif (!lead || !lead.fullName) {\n  return [];\n}\n\nconst searchQuery = lead.fullName + ' ' + ((lead.linkedinSnippet || '').split('.')[0] || '') + ' company website email';\n\nreturn [{\n  json: {\n    ...lead,\n    domainSearchBody: JSON.stringify({ q: searchQuery, num: 3 })\n  }\n}];"
      },
